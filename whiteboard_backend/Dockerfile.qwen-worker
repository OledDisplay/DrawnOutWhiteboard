FROM vllm/vllm-openai:latest

ENV PYTHONUNBUFFERED=1 \
    HF_HOME=/models/huggingface \
    HUGGINGFACE_HUB_CACHE=/models/huggingface \
    TRANSFORMERS_CACHE=/models/huggingface

WORKDIR /workspace/whiteboard_backend

# The vLLM image already carries CUDA, PyTorch, vLLM, transformers, FastAPI,
# and uvicorn. Keep this layer tiny: only fill common gaps used by our server.
RUN python3 -m pip install --no-cache-dir pillow requests

EXPOSE 8009

ENTRYPOINT []
CMD ["bash", "-lc", "cd /workspace/whiteboard_backend/LLMstuff && python3 qwen_vllm_server.py --host 0.0.0.0 --port 8009 --verbose"]
